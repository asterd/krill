# krill.yaml.example — copy to krill.yaml and fill in your values
# $VAR references are expanded from environment variables at startup.

core:
  bus_buffer: 512
  max_clients: 2000
  sandbox_type: exec
  skill_timeout_ms: 30000
  memory_window: 100
  memory_backend: sqlite          # sqlite | file | ram
  memory_path: ./.krill/memory.db
  log_format: json                 # json | text
  log_generated_code: false        # when true, code_exec logs generated source
  log_generated_code_max_bytes: 4000

otel:
  profile: off                     # off | minimal | standard | debug
  exporter: otlp_http              # none | log | otlp_http
  endpoint: "http://otel-collector:4318"
  service_name: krill
  sample_rate: 1.0                 # 0..1
  flush_interval_ms: 5000
  console_debug: false             # if true print text span-end logs in console

llm:
  default: gpt4o
  backends:
    - name: gpt4o
      base_url: https://api.openai.com
      api_key: $OPENAI_API_KEY
      model: gpt-4o
      max_tokens: 4096

    # Uncomment for local LLM (Ollama, LM Studio, vLLM)
    # - name: local
    #   base_url: http://localhost:11434
    #   api_key: none
    #   model: qwen2.5:14b
    #   max_tokens: 8192

protocols:
  - name: http
    enabled: true
    config:
      addr: ":8080"
      api_key: ""        # leave empty to disable auth, or set $HTTP_API_KEY

  - name: telegram
    enabled: false
    config:
      token: $TELEGRAM_BOT_TOKEN
      poll_ms: 1000

  - name: webhook
    enabled: false
    config:
      addr: ":8081"
      path: "/webhook"
      secret: $WEBHOOK_SECRET
      verify_mode: hmac     # none | hmac | slack | discord
      client_field: user.id
      text_field: text

  - name: a2a
    enabled: false
    config:
      addr: ":8091"
      path: "/a2a/v1/envelope"

  - name: pubsub
    enabled: false
    config:
      broker: nats                 # nats | redis_streams | solace
      endpoint: nats://nats:4222   # scaffold for future external adapters
      topic_in: krill.in
      topic_out: krill.out
      topic_dlq: krill.dlq
      group: krill
      dedup_ttl_ms: 300000
      ack_timeout_ms: 5000
      retry_max: 3
      retry_backoff_ms: 100
      retry_backoff_max_ms: 2000

agents:
  - name: default
    description: General-purpose assistant
    llm: gpt4o
    max_turns: 20
    eager_skills:
      - http_fetch
      - json_format
      - code_exec
    system_prompt: |
      You are a concise, helpful assistant.
      Use tools when they help give a better answer. Be brief.

org_schemas:
  - schema_id: default-coop-v1
    version: v1
    roles:
      - name: router
        kind: router
        agent: default
      - name: specialist
        kind: specialist
        agent: default
      - name: synthesizer
        kind: synthesizer
        agent: default
    handoff_rules:
      - from: router
        to: [specialist]
      - from: specialist
        to: [synthesizer]

workflows:
  - id: default
    orchestration_mode: single
  - id: coop-default
    orchestration_mode: cooperative
    org_schema: default-coop-v1
    policy:
      max_hops: 4
      step_timeout_ms: 30000
      token_budget: 12000
      allowed_pairs:
        - default->default

# skills: []   # add custom exec/wasm skills here
